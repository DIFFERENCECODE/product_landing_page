# ─────────────────────────────────────────────────────────────
#  Meo — Metabolic Intelligence System · environment variables
#  Copy to .env.local and fill in the values.
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Stripe ───────────────────────────────────────────────────
# Test mode for local dev. Use sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from `stripe listen` (local) or
# Stripe Dashboard → Webhooks (production).
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Meo Stripe Price IDs ─────────────────────────────────────
# Run scripts/setup-stripe-meo.sh to create products + prices
# automatically. See STRIPE_SETUP.md.

# Main bundle — Meo Starter System (£149 one-time)
NEXT_PUBLIC_KIT_PRICE_ID=price_...

# Upsell: Meo Test Strip Subscription (£15/month recurring)
NEXT_PUBLIC_ADDON_STRIP_SUB_PRICE_ID=price_...

# Upsell: Extend Meo AI — 3 months (£49 one-time)
NEXT_PUBLIC_ADDON_AI_3MO_PRICE_ID=price_...

# Upsell: Extend Meo AI — 12 months (£149 one-time)
NEXT_PUBLIC_ADDON_AI_12MO_PRICE_ID=price_...

# Upsell: Meo Premium Insights (£29/month recurring)
NEXT_PUBLIC_ADDON_PREMIUM_PRICE_ID=price_...

# Downsell: Meo Lite — eBook + 7-day AI trial (£29 one-time)
NEXT_PUBLIC_DOWNSELL_LITE_PRICE_ID=price_...

# Upsell: Multimeter add-on
NEXT_PUBLIC_ADDON_MULTIMETER_PRICE_ID=price_...

# Upsell: Glucose meter
NEXT_PUBLIC_ADDON_GLUCOSE_METER_PRICE_ID=price_...

# Upsell: Syai CGM
NEXT_PUBLIC_ADDON_SYAI_CGM_PRICE_ID=price_...

# Upsell: Glucose strips
NEXT_PUBLIC_ADDON_GLUCOSE_STRIPS_PRICE_ID=price_...

# Upsell: Ketone strips
NEXT_PUBLIC_ADDON_KETONE_STRIPS_PRICE_ID=price_...

# ── Waitlist ─────────────────────────────────────────────────
# Optional: forward waitlist submissions to an external webhook
# (e.g. bang-api /v2/waitlist, AWS SES pipeline).
# If unset, submissions are logged server-side only.
# WAITLIST_WEBHOOK_URL=https://api.meterbolic.org/v2/waitlist

# ── AWS SES (transactional email) ────────────────────────────
# Verify meterbolic.com in SES console before setting these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_REGION=eu-west-1
SES_FROM_EMAIL=Meterbolic <noreply@meterbolic.com>

# ── App ──────────────────────────────────────────────────────
# Public base URL — used to build Stripe success/cancel URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
#  Meterbolic — environment variables
#  Copy this file to .env.local and fill in the values.
#  Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from `stripe listen` or Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ─────────────────────────────────────────
# Create products/prices in Stripe Dashboard (or via CLI) then
# paste the price_xxx IDs below.
#
# Base kit — £197 one-time
NEXT_PUBLIC_KIT_PRICE_ID=price_1TOnKZ...

# Add-on: Glucose & MultiMeter — £60
NEXT_PUBLIC_ADDON_GLUCOSE_MULTI_PRICE_ID=price_...

# Add-on: Glucose Meter — £30
NEXT_PUBLIC_ADDON_GLUCOSE_METER_PRICE_ID=price_...

# Add-on: SyAI CGM — £70
NEXT_PUBLIC_ADDON_CGM_PRICE_ID=price_...

# Add-on: Extra Glucose Strips — £15
NEXT_PUBLIC_ADDON_GLUCOSE_STRIPS_PRICE_ID=price_...

# Add-on: Extra Ketone Strips — £25
NEXT_PUBLIC_ADDON_KETONE_STRIPS_PRICE_ID=price_...

# ── Waitlist ─────────────────────────────────────────────────
# Optional: forward waitlist submissions to an external webhook
# (e.g. AWS SES pipeline, RDS ingestion endpoint).
# If not set, submissions are logged server-side only.
# WAITLIST_WEBHOOK_URL=https://...

# ── App ──────────────────────────────────────────────────────
# Public base URL — used to build absolute success/cancel URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
